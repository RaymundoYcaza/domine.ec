---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, cover, coverAlt, tags } = post.data;

const fecha = pubDate.toLocaleDateString('es-EC', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<a
  href={`/blog/${post.id}`}
  class="group flex flex-col bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200"
>
  <!-- Imagen o placeholder -->
  {cover ? (
    <div class="overflow-hidden h-48">
      <Image
        src={cover}
        alt={coverAlt ?? title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    </div>
  ) : (
    <div class="h-48 bg-brand-yellow/20 flex items-center justify-center">
      <span class="text-5xl">📚</span>
    </div>
  )}

  <!-- Contenido -->
  <div class="flex flex-col flex-1 p-5 gap-3">

    <!-- Tag -->
    {tags?.[0] && (
      <span class="font-display font-bold text-xs uppercase tracking-widest text-brand-yellow">
        {tags[0]}
      </span>
    )}

    <!-- Título -->
    <h3 class="font-display font-extrabold text-lg text-brand-dark leading-snug group-hover:text-brand-yellow transition-colors duration-200">
      {title}
    </h3>

    <!-- Descripción -->
    {description && (
      <p class="text-brand-muted text-sm leading-relaxed line-clamp-2 flex-1">
        {description}
      </p>
    )}

    <!-- Fecha -->
    <p class="text-brand-muted/60 text-xs font-display mt-auto">
      {fecha}
    </p>

  </div>
</a>

