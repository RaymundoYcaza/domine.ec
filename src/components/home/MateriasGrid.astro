---
const materias = [
  {
    slug: 'matematicas',
    nombre: 'Matemáticas',
    icono: '🔢',
    color: 'bg-brand-yellow/20 hover:bg-brand-yellow/40',
    borde: 'border-brand-yellow',
  },
  {
    slug: 'lenguaje',
    nombre: 'Lenguaje',
    icono: '📖',
    color: 'bg-brand-blue/20 hover:bg-brand-blue/40',
    borde: 'border-brand-blue',
  },
  {
    slug: 'ciencias',
    nombre: 'Ciencias',
    icono: '🔬',
    color: 'bg-brand-green/30 hover:bg-brand-green/50',
    borde: 'border-brand-green',
  },
  {
    slug: 'historia',
    nombre: 'Historia',
    icono: '🌎',
    color: 'bg-brand-yellow/20 hover:bg-brand-yellow/40',
    borde: 'border-brand-yellow',
  },
  {
    slug: 'tecnicas-de-estudio',
    nombre: 'Técnicas de estudio',
    icono: '🧠',
    color: 'bg-brand-blue/20 hover:bg-brand-blue/40',
    borde: 'border-brand-blue',
  },
  {
    slug: 'ingles',
    nombre: 'Inglés',
    icono: '💬',
    color: 'bg-brand-green/30 hover:bg-brand-green/50',
    borde: 'border-brand-green',
  },
];
---

<section class="py-16 px-4 bg-white">
  <div class="max-w-5xl mx-auto">

    <h2 class="font-display font-extrabold text-3xl text-brand-dark text-center mb-10">
      ¿Qué quieres aprender hoy?
    </h2>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      {materias.map((m) => (
        <a
          href={`/blog/categoria/${m.slug}`}
          class={`
            ${m.color} ${m.borde}
            border-b-4 rounded-2xl
            flex flex-col items-center justify-center
            gap-3 py-8 px-4
            transition-all duration-200
            group
          `}
        >
          <span class="text-5xl group-hover:scale-110 transition-transform duration-200">
            {m.icono}
          </span>
          <span class="font-display font-bold text-brand-dark text-center leading-tight">
            {m.nombre}
          </span>
        </a>
      ))}
    </div>

  </div>
</section>

