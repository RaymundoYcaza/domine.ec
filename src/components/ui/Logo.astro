---
interface Props {
  width?: number;
  variant?: 'color' | 'light';
}
const { width = 160, variant = 'color' } = Astro.props;

const src = variant === 'light'
  ? '/images/logo-domine-light.svg'
  : '/images/logo-domine-color.svg';
---

<a href="/" aria-label="Dómine">
  <img src={src} alt="Dómine" width={width} height="auto" loading="lazy" />
</a>

