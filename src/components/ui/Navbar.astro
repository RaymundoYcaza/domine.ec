---
import Logo from '@/components/ui/Logo.astro';

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="w-full bg-white border-b border-brand-blue/30 sticky top-0 z-50">

  <!-- ============ DESKTOP ============ -->
  <nav class="hidden md:grid items-center max-w-6xl mx-auto px-6 py-3"
      style="grid-template-columns: 1fr auto 1fr;">

    <!-- Columna izquierda — se contrae al contenido, no llena 1/3 del ancho -->
    <ul class="flex gap-8 justify-end items-center pr-10">
      <li>
        <a href="/" class:list={['nav-link', isActive('/') && 'nav-link--active']}>
          Inicio
        </a>
      </li>
      <li>
        <a href="/blog" class:list={['nav-link', isActive('/blog') && 'nav-link--active']}>
          Blog
        </a>
      </li>
    </ul>

    <!-- Logo — tamaño natural, centrado -->
    <div class="flex justify-center">
      <Logo width={180} />
    </div>

    <!-- Columna derecha -->
    <ul class="flex gap-6 justify-start items-center pl-10">
      <li>
        <a href="/contacto" class:list={['nav-link', isActive('/contacto') && 'nav-link--active']}>
          Contacto
        </a>
      </li>
      <li>
        <a href="/contacto"
          class="bg-brand-yellow text-brand-dark font-display font-bold px-5 py-2 rounded-full text-sm hover:bg-brand-green transition-colors duration-200">
          Empezar ahora
        </a>
      </li>
    </ul>

  </nav>

  <!-- ============ MOBILE ============ -->
  <div class="md:hidden flex items-center justify-between px-4 py-3">

    <!-- Espacio vacío izquierda para balancear el botón derecho -->
    <div class="w-10"></div>

    <!-- Logo centrado con mx-auto -->
    <div class="flex-1 flex justify-center">
      <Logo width={180} />
    </div>

    <!-- Hamburger derecha -->
    <button
      id="menu-toggle"
      aria-label="Abrir menú"
      aria-expanded="false"
      class="text-brand-dark p-2 w-10 flex justify-end"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

  </div>

  <!-- Menú mobile desplegable -->
  <div id="mobile-menu" class="md:hidden hidden flex-col px-4 pb-4 gap-4 border-t border-brand-blue/20">
    <a href="/" class:list={['nav-link-mobile', isActive('/') && 'nav-link--active']}>Inicio</a>
    <a href="/blog" class:list={['nav-link-mobile', isActive('/blog') && 'nav-link--active']}>Blog</a>
    <a href="/contacto" class:list={['nav-link-mobile', isActive('/contacto') && 'nav-link--active']}>Contacto</a>
    <a href="/contacto"
      class="bg-brand-yellow text-brand-dark font-display font-bold px-5 py-3 rounded-full text-sm text-center hover:bg-brand-green transition-colors duration-200 mt-2">
      Empezar ahora
    </a>
  </div>

</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>

<style>
  .nav-link {
    font-family: 'Nunito', system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    color: #999897;
    text-decoration: none;
    position: relative;
    padding-bottom: 4px;
    transition: color 0.2s ease;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: #E2BB13;
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.25s ease;
  }
  .nav-link:hover { color: #2F2E2B; }
  .nav-link:hover::after,
  .nav-link--active::after { transform: scaleX(1); }
  .nav-link--active { color: #2F2E2B; }

  .nav-link-mobile {
    font-family: 'Nunito', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    color: #2F2E2B;
    text-decoration: none;
    padding: 8px 0;
    border-bottom: 1px solid #E2BB1320;
    display: block;
  }
  .nav-link-mobile.nav-link--active {
    color: #E2BB13;
  }
</style>

